---
import { menuLinks, siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="mt-auto flex w-full flex-col items-center justify-center gap-y-2 pb-4 pt-8 text-center align-top sm:flex-row sm:justify-between sm:text-sm border-t border-[var(--border)] px-8"
>
	<div class="font-['Fraunces'] text-[var(--gold)] sm:me-4">
		{siteConfig.title}
	</div>
	<nav
		aria-label="More on this site"
		class="flex justify-between space-x-4 text-[var(--muted)] md:w-[14rem] w-auto"
	>
		{
			menuLinks.map((link) => (
				<a class="hover:text-[var(--gold)] transition-colors duration-200" href={link.path}>
					{link.title}
				</a>
			))
		}
	</nav>
</footer>
