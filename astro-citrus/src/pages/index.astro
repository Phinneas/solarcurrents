---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/layout/Header.astro";
import { getAllPosts } from "@/data/post";
import { collectionDateSort } from "@/utils/date";
import { siteConfig } from "@/site.config";

const allPosts = await getAllPosts();
const sortedPosts = allPosts.sort(collectionDateSort);

// Featured posts — use first 3
const featuredPosts = sortedPosts.slice(0, 3) as CollectionEntry<"post">[];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.title} — Honest Solar Guides for Real Life</title>
  <meta name="description" content="Real solar guides for RVs, van life, camping, backpacking, and home. Actual math, honest tradeoffs, and no sales pitch. Solar Currents covers solar energy for your adventures, your home, your life.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="/">☀️ Solar Currents</a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/posts/">Blog</a></li>
    <li><a href="/notes/">Notes</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    <span class="eyebrow">Honest solar guides — no sales pitch</span>
    <h1>Solar that actually works<br><em>for your life.</em></h1>
    <p class="hero-sub">
      Whether you're sizing a rooftop system, powering an RV, or trying to keep a phone charged on a three-week trail — we cover real solar with real numbers, not marketing math.
    </p>
    <div class="ctas">
      <a href="/posts/" class="btn-gold">Read the Guides</a>
      <a href="#pillars" class="btn-ghost">What we cover ↓</a>
    </div>
  </div>
  <div class="scroll-hint"><span>Scroll</span><span>↓</span></div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-item"><span class="dot"></span>Real-world performance data, not spec-sheet math</div>
  <div class="trust-item"><span class="dot"></span>No affiliate pressure on our recommendations</div>
  <div class="trust-item"><span class="dot"></span>We'll tell you when solar isn't worth it</div>
  <div class="trust-item"><span class="dot"></span>Written for skeptics first</div>
</div>

<!-- PILLARS -->
<section class="pillars" id="pillars">
  <div class="wrap">
    <div class="pillar-hd">
      <p class="lbl">What we cover</p>
      <h2 class="sec-h2">Solar for every situation</h2>
      <p class="sec-p">Most solar content is written for one scenario. Solar Currents covers the full range — from apartment balconies to full-time off-grid boondocking.</p>
    </div>
    <div class="pillar-grid">
      <div class="pillar">
        <span class="pillar-icon">🏕️</span>
        <div class="pillar-name">Camping &amp; Outdoor</div>
        <p class="pillar-desc">Backpacking, car camping, overlanding. Which panels actually hold up in the field, and how to size a system for days without reliable sun.</p>
        <span class="pillar-kw">portable solar · backpacking solar · camping power</span>
      </div>
      <div class="pillar">
        <span class="pillar-icon">🚐</span>
        <div class="pillar-name">RV &amp; Van Life</div>
        <p class="pillar-desc">How to size a system for real RV usage — not marketing scenarios. Alternators, shore power, and solar: the full charging picture.</p>
        <span class="pillar-kw">RV solar · van life solar · off-grid power</span>
      </div>
      <div class="pillar">
        <span class="pillar-icon">🏠</span>
        <div class="pillar-name">Home &amp; Renters</div>
        <p class="pillar-desc">Rooftop solar, balcony plug-in panels, and solar generators for people who can't — or don't want to — install a full system.</p>
        <span class="pillar-kw">home solar · balcony solar · plug-in solar</span>
      </div>
      <div class="pillar">
        <span class="pillar-icon">⚡</span>
        <div class="pillar-name">Solar Generators</div>
        <p class="pillar-desc">Are they actually worth it? When does a solar generator make sense vs. a DIY system? The battery math most reviews skip entirely.</p>
        <span class="pillar-kw">solar generators · portable power stations</span>
      </div>
    </div>
  </div>
</section>

<!-- APPROACH -->
<section class="approach">
  <div class="wrap">
    <div class="approach-inner">
      <div>
        <p class="lbl">Our approach</p>
        <h2 class="sec-h2">Why Solar Currents is different</h2>
        <p class="sec-p">Most solar content is written to keep you confident enough to click buy. We write to keep you informed enough to make the right call — even if that call is to wait, or walk away entirely.</p>
      </div>
      <div class="points">
        <div class="pt">
          <div class="pt-num">01</div>
          <div>
            <div class="pt-title">Skepticism-first</div>
            <div class="pt-body">We lead with disadvantages, real-world limitations, and the scenarios where solar underdelivers. Credibility comes from honesty, not enthusiasm.</div>
          </div>
        </div>
        <div class="pt">
          <div class="pt-num">02</div>
          <div>
            <div class="pt-title">Actual math, not marketing math</div>
            <div class="pt-body">We apply real-world derates — temperature, shading, battery chemistry, inverter losses. Not just panel watts × peak sun hours.</div>
          </div>
        </div>
        <div class="pt">
          <div class="pt-num">03</div>
          <div>
            <div class="pt-title">The whole system, not just the panels</div>
            <div class="pt-body">RVers use alternators and shore power too. Backpackers need buffer batteries. We cover how everything works together.</div>
          </div>
        </div>
      </div>
    </div>
    <div class="pull-q">
      <p>"If you leave a Solar Currents article knowing solar might not be right for your setup — we've done our job."</p>
      <cite>— The Solar Currents editorial approach</cite>
    </div>
  </div>
</section>

<!-- FEATURED GUIDES -->
<section class="featured">
  <div class="wrap">
    <p class="lbl">From the blog</p>
    <h2 class="sec-h2">Start here</h2>
    <div class="posts-grid">
      {featuredPosts.map((post) => (
        <a class="post" href={`/posts/${post.slug}/`}>
          <div class="post-topic">{post.data.tags?.[0] ?? "Guide"}</div>
          <div class="post-title">{post.data.title}</div>
          <div class="post-desc">{post.data.description ?? "Read the full guide."}</div>
          <div class="post-read">Read guide <span class="arr">→</span></div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- CTA BAND -->
<div class="cta-band">
  <div class="wrap">
    <h2>Not sure where to start?</h2>
    <p>Browse all our guides — from balcony plug-in solar to full off-grid RV builds. No quiz, no email gate, just the article that answers your actual question.</p>
    <a href="/posts/" class="btn-gold">Browse all guides</a>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="f-brand">Solar Currents</div>
  <div class="f-note">Honest solar guides for real life. Pacific Northwest.</div>
</footer>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #0f1e2e;
    --navy-mid: #152638;
    --navy-light: #1d3249;
    --gold: #e8c84a;
    --cream: #f5f0e8;
    --cream-dim: #c8bfaa;
    --muted: #7a8fa3;
    --border: rgba(232,200,74,0.15);
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--navy);
    color: var(--cream);
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 2.5rem;
    background: rgba(15,30,46,0.94);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 0.55rem;
    font-family: 'Instrument Serif', serif; font-size: 1.2rem;
    color: var(--gold); text-decoration: none;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    color: var(--cream-dim); font-size: 0.875rem;
    text-decoration: none; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-links .docs {
    border: 1px solid var(--gold); color: var(--gold);
    padding: 0.3rem 0.85rem; border-radius: 4px; font-size: 0.8rem;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center; position: relative;
    padding: 8rem 2rem 5rem;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% 15%, rgba(232,200,74,0.07) 0%, transparent 55%),
      radial-gradient(ellipse 50% 50% at 15% 80%, rgba(21,49,74,0.7) 0%, transparent 55%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute; inset: 0; opacity: 0.035;
    background-image:
      linear-gradient(rgba(232,200,74,1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,200,74,1) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .hero-content {
    position: relative; z-index: 2;
    max-width: 760px;
    animation: fadeUp 0.85s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.72rem; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold);
    padding: 0.32rem 0.85rem;
    border: 1px solid rgba(232,200,74,0.3);
    border-radius: 100px;
    margin-bottom: 1.4rem;
  }
  h1 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(2.8rem, 6.5vw, 4.4rem);
    font-weight: 400; line-height: 1.1;
    color: var(--cream);
    margin-bottom: 1.4rem;
  }
  h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 1.1rem; font-weight: 300;
    color: var(--cream-dim); line-height: 1.8;
    max-width: 560px; margin: 0 auto 2.5rem;
  }
  .ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-gold {
    background: var(--gold); color: var(--navy);
    font-size: 0.9rem; font-weight: 500;
    padding: 0.85rem 2rem; border-radius: 6px;
    text-decoration: none; transition: background 0.2s, transform 0.15s;
  }
  .btn-gold:hover { background: #f0d360; transform: translateY(-1px); }
  .btn-ghost {
    background: transparent; color: var(--cream-dim);
    font-size: 0.9rem; font-weight: 400;
    padding: 0.85rem 2rem; border-radius: 6px;
    border: 1px solid rgba(197,191,170,0.3);
    text-decoration: none; transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    color: var(--muted); font-size: 0.68rem; letter-spacing: 0.1em;
    text-transform: uppercase;
    animation: bob 2s ease-in-out infinite;
  }
  @keyframes bob {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(6px); }
  }

  /* TRUST BAR */
  .trust-bar {
    background: var(--navy-mid);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.15rem 2.5rem;
    display: flex; justify-content: center;
    gap: 2.5rem; flex-wrap: wrap;
  }
  .trust-item {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: var(--muted); letter-spacing: 0.03em;
  }
  .dot { width: 5px; height: 5px; background: var(--gold); border-radius: 50%; flex-shrink: 0; }

  /* SHARED SECTION */
  section { padding: 5rem 2rem; }
  .wrap { max-width: 1100px; margin: 0 auto; }
  .lbl {
    font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.65rem;
  }
  .sec-h2 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.7rem);
    font-weight: 400; color: var(--cream);
    line-height: 1.2; margin-bottom: 0.9rem;
  }
  .sec-p {
    font-size: 1rem; font-weight: 300;
    color: var(--cream-dim); line-height: 1.8;
    max-width: 540px;
  }

  /* PILLARS */
  .pillars { background: var(--navy); }
  .pillar-hd { margin-bottom: 3.5rem; }
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px,1fr));
    gap: 1.5px; background: var(--border);
    border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
  }
  .pillar {
    background: var(--navy-mid);
    padding: 2rem 1.75rem;
    transition: background 0.2s;
  }
  .pillar:hover { background: var(--navy-light); }
  .pillar-icon { font-size: 1.75rem; display: block; margin-bottom: 0.9rem; }
  .pillar-name {
    font-family: 'Instrument Serif', serif;
    font-size: 1.15rem; color: var(--cream); margin-bottom: 0.45rem;
  }
  .pillar-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.65; font-weight: 300; }
  .pillar-kw {
    display: inline-block; margin-top: 1rem;
    font-size: 0.68rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--gold); opacity: 0.65;
  }

  /* APPROACH */
  .approach { background: var(--navy-mid); }
  .approach-inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: start;
  }
  .points { display: flex; flex-direction: column; gap: 0; }
  .pt {
    display: flex; gap: 1.1rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .pt:last-child { border-bottom: none; }
  .pt-num {
    font-family: 'Instrument Serif', serif;
    font-size: 1.9rem; color: rgba(232,200,74,0.18);
    line-height: 1; flex-shrink: 0; width: 2.2rem;
  }
  .pt-title { font-size: 0.92rem; font-weight: 500; color: var(--cream); margin-bottom: 0.25rem; }
  .pt-body { font-size: 0.8rem; color: var(--muted); line-height: 1.7; font-weight: 300; }
  .pull-q {
    margin-top: 4rem;
    background: var(--navy-light);
    border-left: 3px solid var(--gold);
    padding: 1.75rem 2.25rem;
    border-radius: 0 8px 8px 0;
  }
  .pull-q p {
    font-family: 'Instrument Serif', serif;
    font-size: 1.35rem; font-style: italic;
    color: var(--cream); line-height: 1.5; margin-bottom: 0.75rem;
  }
  .pull-q cite { font-size: 0.73rem; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; font-style: normal; }

  /* FEATURED */
  .featured { background: var(--navy); }
  .posts-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5px; background: var(--border);
    border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
    margin-top: 3rem;
  }
  .post {
    background: var(--navy-mid);
    padding: 2rem 1.75rem;
    display: flex; flex-direction: column;
    text-decoration: none; transition: background 0.2s;
  }
  .post:hover { background: var(--navy-light); }
  .post-topic {
    font-size: 0.67rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gold);
    font-weight: 500; margin-bottom: 0.7rem;
  }
  .post-title {
    font-family: 'Instrument Serif', serif;
    font-size: 1.05rem; color: var(--cream);
    line-height: 1.4; flex-grow: 1; margin-bottom: 0.55rem;
  }
  .post-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.65; font-weight: 300; margin-bottom: 1.2rem; }
  .post-read { font-size: 0.75rem; color: var(--gold); display: flex; align-items: center; gap: 0.3rem; }
  .arr { display: inline-block; transition: transform 0.2s; }
  .post:hover .arr { transform: translateX(4px); }

  /* CTA BAND */
  .cta-band {
    background: var(--navy-mid);
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    padding: 4.5rem 2rem; text-align: center;
  }
  .cta-band h2 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 400; color: var(--cream); margin-bottom: 0.9rem;
  }
  .cta-band p {
    font-size: 1rem; font-weight: 300;
    color: var(--cream-dim); max-width: 480px;
    margin: 0 auto 2rem; line-height: 1.75;
  }

  /* FOOTER */
  footer {
    padding: 2.25rem 2.5rem;
    display: flex; justify-content: space-between;
    align-items: center; flex-wrap: wrap; gap: 1rem;
    border-top: 1px solid var(--border);
  }
  .f-brand { font-family: 'Instrument Serif', serif; color: var(--gold); font-size: 1rem; }
  .f-note { font-size: 0.73rem; color: var(--muted); }

  /* RESPONSIVE */
  @media (max-width: 800px) {
    nav { padding: 1rem 1.25rem; }
    .nav-links { gap: 1.2rem; }
    .approach-inner { grid-template-columns: 1fr; gap: 3rem; }
    .posts-grid { grid-template-columns: 1fr; }
    .trust-bar { gap: 1.25rem; }
  }
  @media (max-width: 500px) {
    .nav-links { display: none; }
    h1 { font-size: 2.4rem; }
  }
</style>

</body>
</html>
